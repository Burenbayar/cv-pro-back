PORT=3000
NODE_ENV=development
# Comma-separated. Production (Render): https://cv-pro-back.vercel.app or *.vercel.app or *
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
FRONTEND_URL=https://cv-pro-back.vercel.app
JSON_LIMIT=2mb
CV_TEXT_MAX_LENGTH=40000
CACHE_TTL_MS=300000
SESSION_TTL_MS=604800000
AUTH_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
OPENAI_TIMEOUT_MS=120000
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=8192
OPENAI_API_KEY=your-openai-api-key-here
# openai | gemini | auto (gemini then openai fallback)
AI_PROVIDER=auto
DATABASE_URL=postgresql://postgres:password@localhost:5432/cv_ai_pro
GEMINI_API_KEY=your-gemini-api-key-here
# Comma-separated fallbacks (avoid gemini-1.5-flash — 404 on v1beta)
GEMINI_MODEL=gemini-2.0-flash-lite,gemini-2.5-flash,gemini-2.0-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_OUTPUT_TOKENS=4000
